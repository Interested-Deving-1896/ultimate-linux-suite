pkgname=ultimate-linux-suite-git
pkgver=r1.22ea95f
pkgrel=1
pkgdesc="Comprehensive Linux system management toolkit (git version)"
arch=('any')
url="https://github.com/Nerds489/ultimate-linux-suite"
license=('MIT')
depends=('bash' 'coreutils' 'grep' 'sed' 'gawk' 'util-linux')
optdepends=(
    'pciutils: PCI device detection'
    'usbutils: USB device detection'
    'dmidecode: DMI/SMBIOS hardware info'
    'smartmontools: disk health monitoring'
    'flatpak: Flatpak application support'
    'lsb-release: LSB release information'
)
makedepends=('git')
provides=('ultimate-linux-suite')
conflicts=('ultimate-linux-suite')
source=("$pkgname::git+https://github.com/Nerds489/ultimate-linux-suite.git")
sha256sums=('SKIP')

pkgver() {
    cd "$srcdir/$pkgname"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
    cd "$srcdir/$pkgname"

    # Create directories
    install -d "$pkgdir/usr/share/ultimate-linux-suite"
    install -d "$pkgdir/usr/bin"
    install -d "$pkgdir/usr/share/doc/ultimate-linux-suite"
    install -d "$pkgdir/usr/share/licenses/ultimate-linux-suite"

    # Install main script
    install -Dm755 ultimate.sh "$pkgdir/usr/share/ultimate-linux-suite/ultimate.sh"

    # Install directories
    cp -r lib "$pkgdir/usr/share/ultimate-linux-suite/"
    cp -r modules "$pkgdir/usr/share/ultimate-linux-suite/"
    cp -r menus "$pkgdir/usr/share/ultimate-linux-suite/"
    cp -r backends "$pkgdir/usr/share/ultimate-linux-suite/"
    cp -r apps "$pkgdir/usr/share/ultimate-linux-suite/"
    cp -r configs "$pkgdir/usr/share/ultimate-linux-suite/"
    cp -r drivers "$pkgdir/usr/share/ultimate-linux-suite/"

    # Create wrapper script
    cat > "$pkgdir/usr/bin/ultimate-linux-suite" << 'EOF'
#!/bin/bash
exec /usr/share/ultimate-linux-suite/ultimate.sh "$@"
EOF
    chmod 755 "$pkgdir/usr/bin/ultimate-linux-suite"

    # Install documentation
    install -Dm644 README.md "$pkgdir/usr/share/doc/ultimate-linux-suite/README.md"
    install -Dm644 CHANGELOG.md "$pkgdir/usr/share/doc/ultimate-linux-suite/CHANGELOG.md"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/ultimate-linux-suite/LICENSE"
}
