post_install() {
    echo ""
    echo "==> Ultimate Linux Suite installed successfully!"
    echo ""
    echo "    Run with: ultimate-linux-suite"
    echo "    Or:       sudo ultimate-linux-suite (for system changes)"
    echo ""
    echo "    Documentation: /usr/share/doc/ultimate-linux-suite/"
    echo ""
}

post_upgrade() {
    post_install
}
